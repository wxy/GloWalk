    "NSCameraUsageDescription" : {
      "extractionState" : "manual",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "GloWalk uses the rear camera to sense ambient brightness. No photos, no video, no storage."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "GloWalk 用后摄像头感知环境明暗变化，不拍照、不录像、不存储任何画面。拒绝后需手动调节亮度。"
          }
        }
      }
    },
    "NSLocationWhenInUseUsageDescription" : {
      "extractionState" : "manual",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "GloWalk records your walking path to generate night walk posters. Data stays on device."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "GloWalk 记录你的步行路径，用于生成夜路足迹海报。数据仅存于本机。"
          }
        }
      }
    },
    "NSMotionUsageDescription" : {
      "extractionState" : "manual",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "GloWalk uses motion sensors to detect walking state and phone posture for adaptive brightness."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "GloWalk 用运动传感器识别步行状态和手机持握姿态，自动调节闪光灯亮度。"
          }
        }
      }
    },
    "NSPhotoLibraryAddUsageDescription" : {
      "extractionState" : "manual",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Save night walk posters to your photo library."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "保存夜路海报到相册。"
          }
        }
      }
    },
