    "privacy.item1": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Camera only senses ambient light \u2014 no photos, no video, no storage"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "\u6444\u50cf\u5934\u4ec5\u7528\u4e8e\u611f\u77e5\u73af\u5883\u5149\u7ebf\uff0c\u4e0d\u62cd\u7167\u3001\u4e0d\u5f55\u50cf\u3001\u4e0d\u5b58\u50a8\u753b\u9762"
          }
        }
      }
    },
    "privacy.item2": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Path data stored only on your device \u2014 never uploaded"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "\u8def\u5f84\u6570\u636e\u53ea\u5b58\u4e8e\u4f60\u7684\u624b\u673a\uff0c\u4e0d\u4f1a\u4e0a\u4f20\u5230\u4efb\u4f55\u670d\u52a1\u5668"
          }
        }
      }
    },
    "privacy.item3": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "No ads, no tracking, no third-party SDKs"
