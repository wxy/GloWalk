    "camera.description" : {
      "extractionState" : "manual",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "GloWalk uses the rear camera to sense ambient brightness\n\nNo photos, no video, no storage\nA sample is taken every 5 seconds and discarded\n\nIf denied, manual brightness control will be used"
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "GloWalk 用后摄像头感知环境明暗变化\n\n不拍照、不录像、不存储任何画面\n每 5 秒采样一次即丢弃\n\n拒绝后需手动调节亮度"
          }
        }
      }
    },
