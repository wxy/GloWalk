    "camera.description": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "GloWalk senses the darkness around you through the rear camera.\n\nNo photos are taken. No video is recorded.\nA glance every few seconds, then forgotten.\n\nYou may also adjust brightness by hand."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "GloWalk \u7528\u540e\u6444\u50cf\u5934\u611f\u77e5\u73af\u5883\u660e\u6697\u53d8\u5316\n\n\u4e0d\u62cd\u7167\u3001\u4e0d\u5f55\u50cf\u3001\u4e0d\u5b58\u50a8\u4efb\u4f55\u753b\u9762\n\u6bcf 5 \u79d2\u91c7\u6837\u4e00\u6b21\u5373\u4e22\u5f03\n\n\u62d2\u7edd\u540e\u9700\u624b\u52a8\u8c03\u8282\u4eae\u5ea6"
          }
        }
      }
    },
