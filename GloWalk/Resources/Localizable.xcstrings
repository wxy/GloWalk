        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "\u6ca1\u6709\u5e7f\u544a\u3001\u6ca1\u6709\u8ffd\u8e2a\u3001\u6ca1\u6709\u7b2c\u4e09\u65b9 SDK"
          }
        }
      }
    },
    "privacy.item4": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "You can revoke any permission at any time in Settings"
